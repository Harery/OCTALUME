{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://octalume.dev/schemas/agent.schema.json",
  "title": "Agent",
  "description": "An AI agent in the OCTALUME framework",
  "type": "object",
  "required": ["id", "name", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Agent ID"
    },
    "name": {
      "type": "string",
      "description": "Agent name"
    },
    "phase": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 8,
      "description": "Phase number this agent is assigned to"
    },
    "status": {
      "type": "string",
      "enum": ["idle", "running", "completed", "failed", "timeout"],
      "description": "Agent status"
    },
    "current_task": {
      "type": ["string", "null"],
      "description": "Current task being executed"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agent capabilities"
    },
    "config": {
      "type": "object",
      "description": "Agent configuration"
    },
    "last_heartbeat": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Last heartbeat timestamp"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 60,
      "description": "Task timeout in seconds"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of retry attempts"
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum retry attempts"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
